{
  "name": "jpop-hk-concerts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:sources": "node --experimental-strip-types scripts/check-sources.mjs",
    "seed:firestore": "node --experimental-strip-types scripts/seed-firestore.mjs",
